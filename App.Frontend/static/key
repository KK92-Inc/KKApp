#!/usr/bin/env bash
set -euo pipefail

KEY_PRIV="$HOME/.ssh/id_ed25519_tmp"
KEY_PUB="$HOME/.ssh/id_ed25519_tmp.pub"

copy_to_clipboard() {
  if command -v pbcopy &>/dev/null; then
    pbcopy # macOS
  elif command -v wl-copy &>/dev/null; then
    wl-copy # Linux (Wayland)
  elif command -v xclip &>/dev/null; then
    xclip -selection clipboard # Linux (X11)
  elif command -v xsel &>/dev/null; then
    xsel --clipboard --input # Linux (X11 alternative)
  elif command -v clip.exe &>/dev/null; then
    clip.exe # WSL
  else
    return 1
  fi
}

if [[ ! -f "$KEY_PUB" ]]; then
  echo "🔑 No SSH key found. Generating a new Ed25519 key..."
  ssh-keygen -t ed25519 -f "$KEY_PRIV" -N ""
  STATUS="Created a new Ed25519 key."
else
  STATUS="Found existing Ed25519 key."
fi

echo ""
if copy_to_clipboard < "$KEY_PUB"; then
  echo "════════════════════════════════════════════════════════════"
  echo " ✅ SUCCESS: $STATUS"
  echo " 📋 Your public key is now in your clipboard!"
  echo "════════════════════════════════════════════════════════════"
  echo " You can now paste your key into the Public Key field."
  echo " If you lose your key you can always run this command again."
  echo "════════════════════════════════════════════════════════════"
else
  echo "════════════════════════════════════════════════════════════"
  echo " ⚠️  $STATUS"
  echo " ❌ No clipboard tool detected: (wl-clipboard or xclip)."
  echo " Here is your public SSH key to copy manually:"
  echo "════════════════════════════════════════════════════════════"
  cat "$KEY_PUB"
  echo "════════════════════════════════════════════════════════════"
fi
