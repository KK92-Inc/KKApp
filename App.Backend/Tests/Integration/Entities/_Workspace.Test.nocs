// Tests/Integration/Controllers/WorkspaceControllerAddProjectIntegrationTests.cs

using System.Net;
using System.Net.Http.Json;
using System.Text.Json;
using App.Backend.Core;
using App.Backend.Database;
using App.Backend.Domain.Entities;
using App.Backend.Domain.Entities.Users;
using App.Backend.Domain.Enums;
using App.Backend.Models.Responses.Entities.Projects;
using Bogus;
using Microsoft.EntityFrameworkCore;

namespace App.Backend.Tests.Integration.Entities;

public class WorkspaceIntegrationTests
{
    private static readonly Faker Faker = new();

    // - Test that you can add/remove a cursus to a workspace
    // - Test that you can add/remove a goal to a workspace
    // - Test that you can add/remove a rubric to a workspace
    // - Test that you can add/remove a project to a workspace
    // - Test that you cannot add the same project, goal, cursus or rubric twice to a workspace

    #region Helpers

    /// <summary>
    /// Creates a user owning their own personal workspace and returns both.
    /// </summary>
    private static async Task<(User Owner, Workspace Workspace)> SeedOwnedWorkspaceAsync(DatabaseContext db)
    {
        var userResult = await db.Users.AddAsync(new User
        {
            Login = Faker.Internet.UserName(),
        });

        var workspace = new Workspace
        {
            OwnerId = userResult.Entity.Id,
            Ownership = EntityOwnership.User,
        };

        db.Workspaces.Add(workspace);
        await db.SaveChangesAsync();

        return (userResult.Entity, workspace);
    }

    /// <summary>
    /// Creates a plain user that is not associated with any workspace.
    /// Useful for testing forbidden/unauthorized access from an outsider.
    /// </summary>
    private static async Task<User> SeedUserAsync(DatabaseContext db)
    {
        var userResult = await db.Users.AddAsync(new User
        {
            Login = Faker.Internet.UserName(),
        });

        await db.SaveChangesAsync();
        return userResult.Entity;
    }

    /// <summary>
    /// Inserts a project directly into the database for a given workspace.
    /// </summary>
    private static async Task<Project> SeedProjectAsync(DatabaseContext db, Guid workspaceId, string? name = null)
    {
        name ??= Faker.Commerce.ProductName();

        var project = new Project
        {
            Id = Guid.NewGuid(),
            Description = Faker.Lorem.Sentence(),
            Active = true,
            Public = true,
            WorkspaceId = workspaceId,
            Name = name,
            Slug = name.ToSlug(),
        };

        db.Projects.Add(project);
        await db.SaveChangesAsync();

        return project;
    }

    /// <summary>
    /// Builds a valid request body for POST /workspace/{workspace}/project.
    /// </summary>
    private static object BuildPostProjectRequest(string? name = null, bool active = true, bool @public = true)
    {
        return new
        {
            name = name ?? Faker.Commerce.ProductName(),
            description = Faker.Lorem.Sentence(),
            active,
            @public,
            maxMembers = Faker.Random.Int(1, 10),
        };
    }

    /// <summary>
    /// Builds a valid request body for POST /workspace/{workspace}/cursus.
    /// </summary>
    private static object BuildPostCursusRequest(string? name = null, bool active = true, bool @public = true)
    {
        return new
        {
            name = name ?? Faker.Commerce.Department(),
            description = Faker.Lorem.Sentence(),
            active,
            @public,
            variant = "Static",
            completionMode = "Ring",
        };
    }

    /// <summary>
    /// Builds a valid request body for POST /workspace/{workspace}/goal.
    /// </summary>
    private static object BuildPostGoalRequest(string? name = null, bool active = true, bool @public = true)
    {
        return new
        {
            name = name ?? Faker.Commerce.ProductMaterial() + " " + Faker.Commerce.ProductName(),
            description = Faker.Lorem.Sentence(),
            active,
            @public,
        };
    }

    /// <summary>
    /// Builds a valid request body for POST /workspace/{id}/rubric.
    /// </summary>
    private static object BuildPostRubricRequest(string? name = null, bool enabled = true, bool @public = true)
    {
        return new
        {
            name = name ?? Faker.Commerce.ProductName() + " Rubric",
            markdown = Faker.Lorem.Paragraph(),
            enabled,
            @public,
            projectId = (Guid?)null,
            variants = new[]
            {
                new { kind = "Peer", required = 1 },
            },
        };
    }

    #endregion

    [Fact]
    public async Task Workspace_Delete_Project()
    {
        using var factory = new ApiFactory();
        using var db = factory.CreateDbContext();

        var (owner, workspace) = await SeedOwnedWorkspaceAsync(db);
        var project = await SeedProjectAsync(db, workspace.Id);

        var client = factory.CreateClient(owner.Id.ToString());
        var response = await client.DeleteAsync($"/workspace/{workspace.Id}/project/{project.Id}");

        Assert.Equal(HttpStatusCode.NoContent, response.StatusCode);

        using var verifyDb = factory.CreateDbContext();
        Assert.False(await verifyDb.Projects.AnyAsync(p => p.Id == project.Id));
    }

    [Fact]
    public async Task Post_Workspace_Project_Creates_Project()
    {
        using var factory = new ApiFactory();
        using var db = factory.CreateDbContext();

        var (owner, workspace) = await SeedOwnedWorkspaceAsync(db);

        var name = Faker.Commerce.ProductName();
        var request = BuildPostProjectRequest(name);

        var client = factory.CreateClient(owner.Id.ToString());
        var response = await client.PostAsJsonAsync($"/workspace/{workspace.Id}/project", request);

        Assert.Equal(HttpStatusCode.OK, response.StatusCode);

        var projectResponse = await response.Content.ReadFromJsonAsync<ProjectDO>();
        Assert.NotNull(projectResponse);
        Assert.Equal(name, projectResponse!.Name);
        Assert.Equal(name.ToSlug(), projectResponse.Slug);

        using var verifyDb = factory.CreateDbContext();
        Assert.Equal(1, await verifyDb.Projects.CountAsync(p => p.WorkspaceId == workspace.Id && p.Slug == name.ToSlug()));
    }

    [Fact]
    public async Task Post_Workspace_Project_Returns_Conflict_When_Slug_Already_Taken()
    {
        using var factory = new ApiFactory();
        using var db = factory.CreateDbContext();

        var (owner, workspace) = await SeedOwnedWorkspaceAsync(db);
        var existingProject = await SeedProjectAsync(db, workspace.Id);

        // Re-use the exact same name so the generated slug collides.
        var request = BuildPostProjectRequest(existingProject.Name);

        var client = factory.CreateClient(owner.Id.ToString());
        var response = await client.PostAsJsonAsync($"/workspace/{workspace.Id}/project", request);

        Assert.Equal(HttpStatusCode.Conflict, response.StatusCode);

        using var verifyDb = factory.CreateDbContext();
        Assert.Equal(1, await verifyDb.Projects.CountAsync(p => p.Slug == existingProject.Slug));
    }

    [Fact]
    public async Task Post_Workspace_Project_Returns_Forbidden_For_NonMember()
    {
        using var factory = new ApiFactory();
        using var db = factory.CreateDbContext();

        var (_, workspace) = await SeedOwnedWorkspaceAsync(db);
        var outsider = await SeedUserAsync(db);

        var request = BuildPostProjectRequest();

        var client = factory.CreateClient(outsider.Id.ToString());
        var response = await client.PostAsJsonAsync($"/workspace/{workspace.Id}/project", request);

        Assert.Equal(HttpStatusCode.Forbidden, response.StatusCode);
    }

    [Fact]
    public async Task Post_Workspace_Cursus_Creates_Cursus()
    {
        using var factory = new ApiFactory();
        using var db = factory.CreateDbContext();

        var (owner, workspace) = await SeedOwnedWorkspaceAsync(db);

        var name = Faker.Commerce.Department();
        var request = BuildPostCursusRequest(name);

        var client = factory.CreateClient(owner.Id.ToString());
        var response = await client.PostAsJsonAsync($"/workspace/{workspace.Id}/cursus", request);

        Assert.Equal(HttpStatusCode.OK, response.StatusCode);

        using var json = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
        var root = json.RootElement;

        Assert.Equal(name, root.GetProperty("name").GetString());
        Assert.Equal(name.ToSlug(), root.GetProperty("slug").GetString());
        Assert.True(Guid.TryParse(root.GetProperty("id").GetString(), out _));
    }

    [Fact]
    public async Task Post_Workspace_Goal_Creates_Goal()
    {
        using var factory = new ApiFactory();
        using var db = factory.CreateDbContext();

        var (owner, workspace) = await SeedOwnedWorkspaceAsync(db);

        var name = $"{Faker.Commerce.ProductMaterial()} {Faker.Commerce.ProductName()}";
        var request = BuildPostGoalRequest(name);

        var client = factory.CreateClient(owner.Id.ToString());
        var response = await client.PostAsJsonAsync($"/workspace/{workspace.Id}/goal", request);

        Assert.Equal(HttpStatusCode.OK, response.StatusCode);

        using var json = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
        var root = json.RootElement;

        Assert.Equal(name, root.GetProperty("name").GetString());
        Assert.Equal(name.ToSlug(), root.GetProperty("slug").GetString());
        Assert.True(Guid.TryParse(root.GetProperty("id").GetString(), out _));
    }

    [Fact]
    public async Task Post_Workspace_Rubric_Creates_Rubric()
    {
        using var factory = new ApiFactory();
        using var db = factory.CreateDbContext();

        var (owner, workspace) = await SeedOwnedWorkspaceAsync(db);

        var name = $"{Faker.Commerce.ProductName()} Rubric";
        var request = BuildPostRubricRequest(name);

        var client = factory.CreateClient(owner.Id.ToString());
        var response = await client.PostAsJsonAsync($"/workspace/{workspace.Id}/rubric", request);

        Assert.Equal(HttpStatusCode.OK, response.StatusCode);

        using var json = JsonDocument.Parse(await response.Content.ReadAsStringAsync());
        var root = json.RootElement;

        Assert.Equal(name, root.GetProperty("name").GetString());
        Assert.Equal(name.ToSlug(), root.GetProperty("slug").GetString());
        Assert.True(root.GetProperty("enabled").GetBoolean());
        Assert.True(Guid.TryParse(root.GetProperty("id").GetString(), out _));
    }
}